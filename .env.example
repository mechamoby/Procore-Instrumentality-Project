# =============================================================================
# SteelSync Platform — Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values.
# Lines marked [SECRET] must never be committed with real values.
# Lines marked [OPTIONAL] have working defaults — override only if needed.
# =============================================================================

# --- PostgreSQL Database ---
# Used by: steelsync_db.py, sync_agent.py, init-intelligence-layer.py
EVA00_DB=nerv_eva00
EVA00_DB_USER=moby
EVA00_DB_HOST=localhost
EVA00_DB_PORT=5432

# Docker Compose database credentials (used by deployment template)
POSTGRES_USER=eva
POSTGRES_PASSWORD=your_postgres_password_here          # [SECRET]
POSTGRES_DB=nerv

# --- Anthropic API ---
# Used by: synthesis_engine.py (Claude-powered synthesis and Radar)
ANTHROPIC_API_KEY=sk-ant-your-key-here                 # [SECRET]
SYNTHESIS_MODEL=claude-sonnet-4-20250514               # [OPTIONAL] default: claude-sonnet-4-20250514

# --- Local LLM (Ollama) ---
# Used by: signal_generation.py (classification, triage, routing)
OLLAMA_HOST=http://localhost:11434                      # [OPTIONAL] default: http://localhost:11434
SIGNAL_LLM_MODEL=deepseek-r1:8b                        # [OPTIONAL] default: deepseek-r1:8b

# --- NERV Interface (Web Server) ---
# Used by: server.py
PORT=8080                                              # [OPTIONAL] default: 8080

# --- OpenClaw Gateway ---
# Used by: server.py, katsuragi-email.py
OPENCLAW_GATEWAY_TOKEN=your_gateway_token_here         # [SECRET]
OPENCLAW_GATEWAY_PORT=18789                            # [OPTIONAL] default: 18789

# --- Procore Integration ---
# Used by: sync_agent.py, docker-compose.yml
PROCORE_CLIENT_ID=your_procore_client_id_here          # [SECRET]
PROCORE_CLIENT_SECRET=your_procore_client_secret_here  # [SECRET]
PROCORE_COMPANY_ID=4281379                             # Sandbox default
PROCORE_PROJECT_IDS=316469                             # Comma-separated project IDs

# --- SMTP (Outbound Email) ---
# Used by: server.py, notification-engine
SMTP_HOST=smtp.gmail.com                               # [OPTIONAL] default: smtp.gmail.com
SMTP_PORT=587                                          # [OPTIONAL] default: 587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_smtp_password_here                  # [SECRET]
SMTP_FROM=steelsync@yourdomain.com                     # [OPTIONAL]

# --- IMAP (Inbound Email Ingestion) ---
# Used by: ingest_email.py
IMAP_HOST=imap.gmail.com                               # [OPTIONAL] default: imap.gmail.com
IMAP_PORT=993                                          # [OPTIONAL] default: 993
IMAP_USER=your_email@gmail.com
IMAP_PASS=your_imap_password_here                      # [SECRET]

# --- Telegram Notifications ---
# Used by: watchdog, notification-engine
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here        # [SECRET] [OPTIONAL]
TELEGRAM_CHAT_ID=your_telegram_chat_id_here            # [OPTIONAL]

# --- Procore Sync Agent Tuning ---
# Used by: sync_agent.py — all have safe defaults
SYNC_API_DELAY=0.6                                     # [OPTIONAL] seconds between API calls
SYNC_INTERVAL_PROJECTS=3600                            # [OPTIONAL] seconds
SYNC_INTERVAL_SUBMITTALS=300                           # [OPTIONAL] seconds
SYNC_INTERVAL_RFIS=300                                 # [OPTIONAL] seconds
SYNC_INTERVAL_DRAWINGS=900                             # [OPTIONAL] seconds
SYNC_INTERVAL_COMPANIES=3600                           # [OPTIONAL] seconds
SYNC_INTERVAL_CONTACTS=3600                            # [OPTIONAL] seconds
SYNC_INTERVAL_DOCUMENTS=1800                           # [OPTIONAL] seconds

# --- Redis ---
# Used by: docker-compose.yml (notification-engine, openclaw)
REDIS_PASSWORD=your_redis_password_here                # [SECRET]

# --- DocuSign (Optional Integration) ---
# Used by: deployment template
# DOCUSIGN_INTEGRATION_KEY=your_key_here               # [SECRET] [OPTIONAL]
# DOCUSIGN_SECRET_KEY=your_secret_here                 # [SECRET] [OPTIONAL]
# DOCUSIGN_ACCOUNT_ID=your_account_id_here             # [OPTIONAL]
